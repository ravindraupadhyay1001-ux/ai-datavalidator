# ==========================================================================
# Data Validation Agent — environment configuration
# Copy this file to .env and fill in the values. NEVER commit .env.
# ==========================================================================

# --- AWS / Bedrock (REQUIRED — client's own AWS account) ---
AWS_PROFILE=claudecode
AWS_DEFAULT_REGION=us-east-1
BEDROCK_MODEL_ID=

# --- License (REQUIRED in production) ---
LICENSE_KEY=
LICENSE_SERVER_URL=
LICENSE_PUBLIC_KEY=
LICENSE_GRACE_DAYS=7

# --- Application ---
APP_ROOT=.
JWT_SECRET=change-this-in-production

# --- Database ---
WORKSPACE_DB=sqlite
WORKSPACE_SQLITE_PATH=workspace.db
MSSQL_SERVER=
MSSQL_DATABASE=WorkspaceDB

# --- Email ---
EMAIL_FROM=
SMTP_HOST=
SMTP_PORT=25

# --- Local username/password auth (fallback when no Windows Auth / SSO) ---
LOCAL_AUTH_ENABLED=false

# --- Enterprise SSO -- OIDC (recommended; e.g. Azure AD / Okta / Auth0) ---
OIDC_ENABLED=false
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=
OIDC_ROLE_CLAIM=roles
SSO_ROLE_MAP={}

# --- Enterprise SSO -- SAML 2.0 (optional; requires python3-saml installed
# separately -- see workspace/saml_sso.py docstring) ---
SAML_ENABLED=false
SAML_SP_ENTITY_ID=
SAML_SP_ACS_URL=
SAML_IDP_ENTITY_ID=
SAML_IDP_SSO_URL=
SAML_IDP_X509_CERT=
SAML_ROLE_ATTRIBUTE=roles

# --- LDAP / Active Directory auth ---
LDAP_ENABLED=false
LDAP_SERVER=
LDAP_BASE_DN=
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=

# --- Dev override ---
WORKSPACE_DEV_USER=
