# ==========================================================================
# Data Validation Agent — environment configuration
# Copy this file to .env and fill in the values. NEVER commit .env.
# ==========================================================================

# --- AWS / Bedrock (REQUIRED — client's own AWS account) ---
AWS_PROFILE=claudecode
AWS_DEFAULT_REGION=us-east-1
BEDROCK_MODEL_ID=

# --- License (REQUIRED in production) ---
LICENSE_KEY=
LICENSE_SERVER_URL=
LICENSE_PUBLIC_KEY=
LICENSE_GRACE_DAYS=7

# --- Application ---
APP_ROOT=.
JWT_SECRET=change-this-in-production

# --- Database ---
WORKSPACE_DB=sqlite
WORKSPACE_SQLITE_PATH=workspace.db
MSSQL_SERVER=
MSSQL_DATABASE=WorkspaceDB

# --- Email ---
EMAIL_FROM=
SMTP_HOST=
SMTP_PORT=25

# --- Dev override ---
WORKSPACE_DEV_USER=
